# =============================================================================
# Next.js Frontend Environment Configuration Reference
# =============================================================================

# ─── API Client Configuration ────────────────────────────────────────────────
# Base URL of the Laravel API backend (Render deployment endpoint)
NEXT_PUBLIC_API_URL=https://eckox-ai-platform.onrender.com/api

# ─── Web Analytics Features ──────────────────────────────────────────────────
# Enable or disable Vercel Web Analytics scripts in the layout wrapper
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ─── Optional Frontend-Side AI Playgrounds (Development Only) ────────────────
# These keys are only read if testing mock client-side LLM providers in dev mode.
# In production, all queries route securely via the Laravel backend API.
OPENAI_API_KEY=sk-proj-...                 # Optional OpenAI key for direct client-side playgrounds
CLAUDE_API_KEY=sk-ant-api03-...            # Optional Anthropic key for direct client-side playgrounds
AI_PROVIDER=mock                           # Local playground default provider (mock, openai, claude)
AI_LOGGING=false                           # Enable verbose logging of client-side requests (true/false)
