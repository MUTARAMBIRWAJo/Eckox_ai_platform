# =============================================================================
# Laravel Backend Environment Configuration Reference
# =============================================================================

# ─── App Configuration ───────────────────────────────────────────────────────
APP_NAME="Eckox AI Platform"               # Name of the application
APP_ENV=production                         # Application environment (production, local, testing)
APP_KEY=base64:placeholder=                # Application encryption key (generate with: php artisan key:generate)
APP_DEBUG=false                            # Enable/disable detailed stack traces in responses (true/false)
APP_URL=https://api.eckox.ai               # Base public URL of the backend API

# ─── Localization & Logging ──────────────────────────────────────────────────
APP_LOCALE=en                              # Default application language
APP_FALLBACK_LOCALE=en                     # Fallback language if default is not available
APP_FAKER_LOCALE=en_US                     # Locale used by Faker data generators
LOG_CHANNEL=stderr                         # Logging driver channel (stack, single, stderr, daily)
LOG_LEVEL=error                            # Log filtering level (debug, info, warning, error)

# ─── Database Configuration (PostgreSQL + pgvector) ──────────────────────────
DB_CONNECTION=pgsql                        # Database connection driver name (pgsql)
DB_HOST=127.0.0.1                          # Database server hostname / connection endpoint
DB_PORT=6543                               # Database port number (Supabase pgBouncer transaction pooler uses 6543)
DB_DATABASE=postgres                       # Database name
DB_USERNAME=postgres                       # Database login username
DB_PASSWORD=secret                         # Database login password
DB_SSLMODE=require                         # SSL connection mode (require, disable)

# ─── Redis Cache & Queue ─────────────────────────────────────────────────────
REDIS_CLIENT=phpredis                      # Redis PHP extension client (phpredis, predis)
REDIS_HOST=127.0.0.1                       # Redis server hostname
REDIS_PASSWORD=null                        # Redis server password
REDIS_PORT=6379                            # Redis server port
REDIS_SCHEME=tcp                           # Redis connection protocol (tcp, tls)

# ─── Session & Sanctum / CORS ────────────────────────────────────────────────
SESSION_DRIVER=redis                       # Driver to store sessions (redis, database, cookie)
SESSION_LIFETIME=120                       # Session duration in minutes
SESSION_SECURE_COOKIE=true                 # Restrict session cookies to HTTPS only (true/false)
SESSION_SAME_SITE=lax                      # SameSite cookie attribute (lax, strict, none)
SESSION_DOMAIN=.eckox.ai                   # Session cookie domain scope (use prefix dot to share across subdomains)
SANCTUM_STATEFUL_DOMAINS=eckox.ai,api.eckox.ai,localhost:3000   # Stateful domains for Sanctum cookie authentication
ALLOWED_ORIGINS=https://eckox.ai,http://localhost:3000          # Allowed origins for Cross-Origin Resource Sharing (CORS)

# ─── Queue Manager ───────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis                     # Background job queue driver (redis, sync, database)

# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...                 # OpenAI API key for GPT-4o and GPT-4o-mini reasoning nodes
ANTHROPIC_API_KEY=sk-ant-api03-...         # Anthropic API key for Claude 3.5 Sonnet reasoning fallback node
GROQ_API_KEY=gsk_...                       # Groq API key for LLaMA 3.3 reasoning fallback node
GROQ_BASE_URL=https://api.groq.com/openai/v1  # Base API endpoint URL for Groq client
# ─── Provider Enable/Disable (TEMPORARY: 2026-07 Billing Hold) ─────────────
# Set to 'true' to enable OpenAI/Anthropic once billing is resolved (no code changes needed)
LLM_PROVIDER_OPENAI_ENABLED=false
LLM_PROVIDER_ANTHROPIC_ENABLED=false
LLM_PROVIDER_GROQ_ENABLED=true
# ─── WhatsApp / 360Dialog Integration ────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=token_here              # Access token for WhatsApp 360Dialog integration (authoritative Render config name)
WHATSAPP_BASE_URL=https://waba.360dialog.io/v1 # Base API endpoint URL for WhatsApp 360Dialog
WHATSAPP_PHONE_NUMBER_ID=number_id_here    # Phone number identifier provided by Meta/360Dialog
WHATSAPP_VERIFY_TOKEN=token_here           # Verification token used to register and validate webhooks

# ─── Third-Party Services ────────────────────────────────────────────────────
RESEND_API_KEY=re_...                      # Resend API key for outbound transactional emails
POSTMARK_API_KEY=server_token_here         # Postmark API server token (alternative email driver)
SLACK_BOT_USER_OAUTH_TOKEN=xoxb-...        # OAuth token for Slack bot notification alerts
SLACK_BOT_USER_DEFAULT_CHANNEL=alerts      # Default Slack channel name for error and escalation logs

# ─── Storage & S3 Configuration ──────────────────────────────────────────────
FILESYSTEM_DISK=s3                         # Filesystem disk driver (s3, local, public)
AWS_ACCESS_KEY_ID=key_id_here              # Supabase Storage / AWS S3 access key ID
AWS_SECRET_ACCESS_KEY=secret_here          # Supabase Storage / AWS S3 secret access key
AWS_DEFAULT_REGION=eu-west-1               # S3 storage region
AWS_BUCKET=bucket_name_here                # Storage bucket name
AWS_URL=http://localhost/storage           # Public base URL of the storage files
AWS_ENDPOINT=https://your-project.supabase.co/storage/v1/s3 # Custom S3-compatible API endpoint URL
AWS_USE_PATH_STYLE_ENDPOINT=true           # Force path-style access (required for Supabase/MinIO)

# ─── Outbound Mail Server ────────────────────────────────────────────────────
MAIL_MAILER=smtp                           # Mail transport protocol (smtp, log, ses, resend)
MAIL_HOST=smtp.resend.com                  # SMTP mail server address
MAIL_PORT=465                              # SMTP mail server port
MAIL_USERNAME=resend                       # SMTP authentication username
MAIL_PASSWORD=password_here                # SMTP authentication password / API key
MAIL_ENCRYPTION=ssl                        # Connection encryption protocol (tls, ssl)
MAIL_FROM_ADDRESS=noreply@eckox.ai         # Default email address displayed as sender
MAIL_FROM_NAME="Eckox AI Platform"         # Default name displayed as sender
