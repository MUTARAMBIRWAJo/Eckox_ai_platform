APP_NAME="Eckox AI Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://eckox-backend.fly.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (Supabase PostgreSQL via pgBouncer) ───────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=your-supabase-host.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-db-password
DB_SSLMODE=require

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.eckox.ai
SANCTUM_STATEFUL_DOMAINS=eckox.ai,localhost:3000,localhost

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=your-upstash-redis-host.upstash.io
REDIS_PASSWORD=your-upstash-redis-password
REDIS_PORT=6379
REDIS_SCHEME=tls

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=your-resend-api-key
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@eckox.ai
MAIL_FROM_NAME="Eckox AI"

# ── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-secure-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ── AWS S3 / Supabase Storage ─────────────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=your-supabase-storage-key
AWS_SECRET_ACCESS_KEY=your-supabase-storage-secret
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=your-bucket-name
AWS_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
AWS_USE_PATH_STYLE_ENDPOINT=true

BCRYPT_ROUNDS=12
